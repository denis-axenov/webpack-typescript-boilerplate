{
  "name": "webpack-boilerplate",
  "version": "1.0.0",
  "description": "Webpack bundler",
  "main": "./src/scripts/main.js",
  "scripts": {
    "dev": "webpack serve --mode=development",
    "dev:lint": "webpack serve --mode=development --env lint",
    "watch": "webpack --mode=development --watch",
    "watch:lint": "webpack --mode=development --watch --env lint",
    "build": "webpack --mode=production",
    "lint": "eslint src/scripts && stylelint src/styles/**/*.scss",
    "lint:fix": "eslint src/scripts --fix && stylelint src/styles/**/*.scss --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --collect-coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denis-axenov/webpack-boilerplate.git"
  },
  "keywords": [
    "webpack",
    "bundler",
    "static",
    "scss",
    "eslint",
    "stylelint"
  ],
  "author": "Denis Axenov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/denis-axenov/webpack-boilerplate/issues"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@types/eslint__js": "^8.42.3",
    "autoprefixer": "^10.4.20",
    "css-loader": "^7.1.2",
    "cssnano": "^7.0.6",
    "eslint": "^9.11.1",
    "eslint-webpack-plugin": "^4.2.0",
    "globals": "^15.10.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.1",
    "postcss": "^8.4.47",
    "postcss-loader": "^8.1.1",
    "postcss-preset-env": "^10.0.5",
    "postcss-scss": "^4.0.9",
    "sass": "^1.79.4",
    "sass-loader": "^16.0.2",
    "style-loader": "^4.0.0",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-scss": "^6.7.0",
    "stylelint-webpack-plugin": "^5.0.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
